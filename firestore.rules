rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rate limit counters — only the Functions backend may write these.
    // Users can read their own record to display remaining quota in the UI.
    match /rateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Functions write via Admin SDK (bypasses rules)
    }

    // Active task tracking — same pattern as rate limits.
    match /scheduledTasks/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
