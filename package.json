{
  "name": "@hoeghen/services-kit",
  "version": "0.1.0",
  "description": "Client SDK for Firebase, Google Drive, email, and task scheduling",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hoeghen/services-kit.git"
  },
  "keywords": ["firebase", "google-drive", "email", "scheduler"],
  "license": "MIT",
  "peerDependencies": {
    "firebase": "^10.0.0"
  },
  "dependencies": {
    "googleapis": "^140.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "rollup": "^4.18.0",
    "ts-jest": "^29.1.4",
    "tslib": "^2.6.3",
    "typescript": "^5.4.5"
  }
}
