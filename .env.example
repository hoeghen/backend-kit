# ─── Client-side Firebase config (public — embedded in bundle) ───────────────
# These values are non-secret by design; security is enforced via Firebase Rules.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Google OAuth (client-side — identifies your app, not a secret) ──────────
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── NEVER put these in any frontend env file ────────────────────────────────
# SENDGRID_API_KEY  → set via: firebase functions:config:set sendgrid.key="..."
# SMTP_PASSWORD     → same as above
# Any server-side secret stays exclusively in Firebase Functions environment
