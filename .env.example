# ─── Client-side Firebase config (public — embedded in bundle) ───────────────
# These values are non-secret by design; security is enforced via Firebase Rules.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Google OAuth (client-side — identifies your app, not a secret) ──────────
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Firebase App Check — reCAPTCHA v3 (public site key, safe to embed) ──────
# 1. Register your site at https://www.google.com/recaptcha/admin (choose v3)
# 2. In Firebase console → App Check → Apps, register with reCAPTCHA v3 provider
# 3. In Firebase console → App Check → APIs, enforce App Check on Cloud Functions
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# ─── NEVER put these in any frontend env file ────────────────────────────────
# SENDGRID_API_KEY  → firebase functions:secrets:set SENDGRID_API_KEY
# Any server-side secret stays exclusively in Firebase Functions environment
